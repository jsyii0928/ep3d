begin:control
  nx = 100
  ny = nx
  nz = nx

  # Final time of simulation
  t_end = 150 * femto

  # Size of domain
  x_min = -18 * micron
  x_max = 18 * micron
  y_min = -18 * micron
  y_max = 18 * micron
  z_min = -9 * micron
  z_max = 9 * micron

  stdout_frequency = 10
end:control


begin:boundaries
  bc_x_min = open
  bc_x_max = open
  bc_y_min = periodic
  bc_y_max = periodic
  bc_z_min = periodic
  bc_z_max = periodic
end:boundaries


begin:fields
  ex = "/home/jsy/ep/epoch/Gpulse2.5/build/Ex.dat"
  ey = "/home/jsy/ep/epoch/Gpulse2.5/build/Ey.dat"
  ez = "/home/jsy/ep/epoch/Gpulse2.5/build/Ez.dat"
  bx = "/home/jsy/ep/epoch/Gpulse2.5/build/Bx.dat"
  by = "/home/jsy/ep/epoch/Gpulse2.5/build/By.dat"
  bz = "/home/jsy/ep/epoch/Gpulse2.5/build/Bz.dat"
end:fields


begin:output
  # Simulated time between output dumps
  dt_snapshot = 25 * femto

  # Properties on grid
  grid = always
  ex = always
  ey = always
  ez = always
  bx = always
  by = always
  bz = always
end:output
